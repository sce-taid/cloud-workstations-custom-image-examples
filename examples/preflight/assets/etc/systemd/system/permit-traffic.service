[Unit]
Description=Permit All Traffic When Nginx is Ready
# Ensure this runs after Nginx and config rendering are ready
After=nginx.service config-rendering.service
Requires=nginx.service

[Service]
Type=oneshot
RemainAfterExit=yes

# Probe Nginx on 127.0.0.1 until it responds (Max 60s)
ExecStartPre=/bin/bash -c ' \
  for i in {1..30}; do \
    if curl -s -o /dev/null -w "%%{http_code}" http://127.0.0.1/ | grep -qE "200|302"; then \
      exit 0; \
    fi; \
    sleep 2; \
  done; \
  exit 1'

ExecStart=/google/scripts/traffic_control.sh permit
