set -euo pipefail

# Source common utilities for WORKSTATION_GPU_ENABLED
# shellcheck source=/dev/null
source /google/scripts/common.sh

ANTIGRAVITY_FLAGS=(
  "--no-sandbox"
  "--force-disable-user-env"
)

# Apply stability flags for headless Wayland
ANTIGRAVITY_FLAGS+=(
  "--ozone-platform=wayland"
)

if [[ "${WORKSTATION_GPU_ENABLED}" == "false" ]]; then
  ANTIGRAVITY_FLAGS+=(
    "--disable-gpu"
    "--disable-gpu-compositing"
    "--in-process-gpu"
    "--disable-gpu-sandbox"
    "--disable-dev-shm-usage"
  )
fi

exec /usr/share/antigravity/antigravity "${ANTIGRAVITY_FLAGS[@]}" "$@"
