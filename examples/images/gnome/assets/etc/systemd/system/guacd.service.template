[Unit]
Description=Guacamole Server Container
Wants=docker.service network-online.target ${DESKTOP_SERVICE}
After=docker.service network-online.target

[Service]
Type=simple
ExecStartPre=-/usr/bin/docker rm -f guacd
ExecStartPre=/usr/bin/docker load -i /opt/images/guacd.tar
ExecStart=/usr/bin/docker run --rm --name guacd \
    --network host \
    --cgroupns host \
    guacamole/guacd:${GUACAMOLE_VERSION}
ExecStop=/usr/bin/docker stop guacd
Restart=on-failure
