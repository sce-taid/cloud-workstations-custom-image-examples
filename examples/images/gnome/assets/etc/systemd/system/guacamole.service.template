[Unit]
Description=Guacamole Client Container
Wants=docker.service network-online.target guacd.service config-rendering.service ${DESKTOP_SERVICE}
After=docker.service network-online.target guacd.service config-rendering.service

[Service]
Type=simple
ExecStartPre=-/usr/bin/docker rm -f guacamole
ExecStartPre=/usr/bin/docker load -i /opt/images/guacamole.tar
ExecStart=/usr/bin/docker run --rm --name guacamole \
    --network host \
    --cgroupns host \
    -e GUACAMOLE_HOME=/etc/guacamole \
    -e REMOTE_IP_VALVE_ENABLED=true \
    -e GUACD_HOSTNAME=127.0.0.1 \
    -e GUACD_PORT=4822 \
    -v /etc/guacamole/extensions:/etc/guacamole/extensions:ro \
    -v /etc/guacamole/user-mapping.xml:/etc/guacamole/user-mapping.xml:ro \
    guacamole/guacamole:${GUACAMOLE_VERSION}
ExecStop=/usr/bin/docker stop guacamole
Restart=on-failure
