# Enforce Linux line endings for all shell scripts, templates, and config files
# to prevent "bad interpreter" or "\r: command not found" errors when executed
# inside the Linux container, even if cloned on a Windows machine.

*.sh text eol=lf
*.bash text eol=lf
*.py text eol=lf
Dockerfile text eol=lf
*.template text eol=lf

# Force Linux line endings for frontend code built/run in the container
*.js text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
*.xml text eol=lf
*.service text eol=lf
*.override text eol=lf

# Explicitly declare binary files to prevent corruption
*.zip binary
*.tar binary
*.gz binary
*.jpg binary
*.png binary
